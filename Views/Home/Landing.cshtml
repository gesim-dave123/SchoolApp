@model SchoolApp.Models.LoginModel
@{
    Layout = null;
    ViewData["Title"] = "Welcome";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SchoolApp</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="landing-page">
    <nav class="navbar navbar-expand-lg navbar-dark navbar-landing sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" href="#home">
                <i class="bi bi-mortarboard-fill text-primary me-2"></i>School<span class="text-primary">App</span>
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0 gap-lg-3">
                    <li class="nav-item"><a class="nav-link px-3" href="#home">Home</a></li>
                    <li class="nav-item"><a class="nav-link px-3" href="#about">Features</a></li>
                    <li class="nav-item">
                        <a href="/Auth/Login" class="btn btn-outline-light px-4 rounded-pill ms-lg-2">Sign In</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <section id="home" class="hero">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-sm-12 col-lg-7 text-center text-lg-start">
                    <span class="badge bg-primary bg-opacity-25 text-primary border border-primary border-opacity-25 mb-3 px-3 py-2 rounded-pill">
                        Managed Education Platform
                    </span>
                    <h1 class="hero-title fw-bold mb-4">The Smarter Way to <span class="text-primary">Manage</span> Your School.</h1>
                    <p class="lead text-light opacity-75 mb-5 fs-4">A unified platform for administrative control, role-based security, and real-time financial tracking.</p>
                    <div class="d-flex flex-column flex-sm-row justify-content-center justify-content-lg-start gap-3">
                        <a href="/Auth/Login" class="btn btn-primary btn-lg px-5 py-3 btn-glow">
                            Get Started <i class="bi bi-arrow-right ms-2"></i>
                        </a>
                        <a href="#about" class="btn btn-link text-white text-decoration-none d-flex align-items-center justify-content-center">
                            Learn more <i class="bi bi-chevron-down ms-2 mt-1"></i>
                        </a>
                    </div>
                </div>
                <div class="col-sm-12 col-lg-5 d-none d-lg-block">
                    <div class="hero-img-container p-2 bg-white bg-opacity-10 rounded-4 border border-white border-opacity-10 shadow-lg">
                        <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-1.2.1&auto=format&fit=crop&w=800&q=80"
                             class="img-fluid rounded-3 shadow" alt="Dashboard Preview">
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section id="about" class="py-5 my-5">
        <div class="container py-lg-5">
            <div class="text-center mb-5 pb-3">
                <div class="section-label mb-2">Our Capabilities</div>
                <h2 class="fw-bold fs-1">Everything you need in one place</h2>
                <p class="text-muted fs-5 mx-auto" style="max-width: 600px;">Streamline your administrative tasks with our intuitive interface and robust back-end logic.</p>
            </div>

            <div class="row g-4">
                <div class="col-sm-12 col-md-4">
                    <div class="feature-tile h-100">
                        <div class="icon-circle bg-primary bg-opacity-10 text-primary">
                            <i class="bi bi-speedometer2"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Live Insights</h5>
                        <p class="text-muted">Monitor total users and revenue growth in real-time through our modern, responsive dashboard.</p>
                    </div>
                </div>
                <div class="col-sm-12 col-md-4">
                    <div class="feature-tile h-100 border-primary border-opacity-25 shadow-sm">
                        <div class="icon-circle bg-success bg-opacity-10 text-success">
                            <i class="bi bi-shield-lock"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Granular Roles</h5>
                        <p class="text-muted">Secure your data with Admin and Guest access levels, ensuring sensitive tasks are kept private.</p>
                    </div>
                </div>
                <div class="col-sm-12 col-md-4">
                    <div class="feature-tile h-100">
                        <div class="icon-circle bg-info bg-opacity-10 text-info">
                            <i class="bi bi-cash-stack"></i>
                        </div>
                        <h5 class="fw-bold mb-3">Audit Logs</h5>
                        <p class="text-muted">Keep a complete history of all financial transactions with clear timestamps and user attribution.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <footer id="footer" class="py-5">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-sm-12 col-md-6 text-center text-md-start mb-4 mb-md-0">
                    <h5 class="text-white fw-bold mb-3"><i class="bi bi-mortarboard-fill me-2"></i>SchoolApp</h5>
                    <p class="mb-0">Empowering institutions through modern data management.</p>
                </div>
                <div class="col-sm-12 col-md-6 text-center text-md-end">
                    <div class="d-flex justify-content-center justify-content-md-end gap-4 mb-3">
                        <a href="#" class="text-white opacity-50 hover-opacity-100"><i class="bi bi-twitter"></i></a>
                        <a href="#" class="text-white opacity-50"><i class="bi bi-linkedin"></i></a>
                        <a href="#" class="text-white opacity-50"><i class="bi bi-github"></i></a>
                    </div>
                    <div class="small">© @DateTime.Now.Year SchoolApp Platform. All rights reserved.</div>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/vanilla-tilt/1.8.1/vanilla-tilt.min.js" integrity="sha512-45e0B4Nn0DqCisLpA#0fA401r0+aX002f#4d7b00344d51" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <script>
        // Target the container, not the image itself, for a better effect
        VanillaTilt.init(document.querySelector(".hero-img-container"), {
            max: 15,            
            speed: 400,         
            glare: true,       
            "max-glare": 0.3,   
            gyroscope: false,   
            scale: 1.02         
        });
    </script>
</body>
</html>