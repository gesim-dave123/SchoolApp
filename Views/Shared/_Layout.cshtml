<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SchoolApp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet"/>
    <style>
        body { display: flex; min-height: 100vh; }
        .sidebar {
            width: 240px; min-height: 100vh;
            background: #1e293b; color: white; padding: 20px 0;
            position: fixed; top: 0; left: 0;
        }
        .sidebar .brand { padding: 10px 20px 20px; font-size: 1.2rem; font-weight: bold; border-bottom: 1px solid #334155; }
        .sidebar .role-badge { padding: 8px 20px; font-size: 0.75rem; color: #94a3b8; text-transform: uppercase; }
        .sidebar a { display: block; padding: 10px 20px; color: #cbd5e1; text-decoration: none; }
        .sidebar a:hover, .sidebar a.active { background: #334155; color: white; }
        .sidebar .nav-section { padding: 8px 20px 4px; font-size: 0.7rem; color: #64748b; text-transform: uppercase; letter-spacing: 1px; margin-top: 10px; }
        .main-content { margin-left: 240px; flex: 1; padding: 30px; background: #f8fafc; }
        .role-switcher { padding: 10px 20px; margin-top: 20px; border-top: 1px solid #334155; }
    </style>
</head>
<body>
@{
    var role = ViewBag.Role as string ?? "guest";
    var isAdmin = role == "admin";
}
<div class="sidebar">
    <div class="brand"><i class="bi bi-grid-3x3-gap-fill me-2"></i>SchoolApp</div>
    <div class="role-badge">Logged in as: <strong>@role.ToUpper()</strong></div>

    <div class="nav-section">Main</div>
    <a href="@Url.Action("Index","Home", new{role})" class="@(ViewContext.RouteData.Values["controller"]?.ToString()=="Home"?"active":"")">
        <i class="bi bi-speedometer2 me-2"></i>Dashboard
    </a>

    <div class="nav-section">Users</div>
    <a href="@Url.Action("Index","Users", new{role})">
        <i class="bi bi-people me-2"></i>View Users
    </a>
    @if (isAdmin)
    {
        <a href="@Url.Action("Create","Users", new{role})">
            <i class="bi bi-person-plus me-2"></i>Add User
        </a>
    }

    <div class="nav-section">Transactions</div>
    <a href="@Url.Action("Index","Transactions", new{role})">
        <i class="bi bi-receipt me-2"></i>View Transactions
    </a>
    @if (isAdmin)
    {
        <a href="@Url.Action("Create","Transactions", new{role})">
            <i class="bi bi-plus-circle me-2"></i>Add Transaction
        </a>
    }

    <div class="role-switcher">
        <label class="text-muted small">Switch Role:</label>
        <select class="form-select form-select-sm mt-1" onchange="window.location='?role='+this.value">
            @if (role == "guest")
            {
                <option value="guest" selected>Guest</option>
                <option value="admin">Admin</option>
            }
            else
            {
                <option value="guest">Guest</option>
                <option value="admin" selected>Admin</option>
            }
        </select>
    </div>
</div>

<div class="main-content">
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @RenderBody()
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>