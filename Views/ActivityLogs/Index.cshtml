@model List<SchoolApp.Models.ActivityLogModel>

<div class="card border-0 shadow-sm" style="border-radius: 16px;">
    <div class="table-responsive">
        <table class="table table-hover table-striped align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">Date</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Action</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Details</th>
                    <th class="py-3 pe-4 text-uppercase small fw-bold text-muted">Performed By</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5 text-muted">No activity logs yet.</td>
                    </tr>
                }
                else
                {
                    @foreach (var log in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-medium">@log.CreatedAt.ToString("MMM dd, yyyy")</div>
                                <div class="small text-muted">@log.CreatedAt.ToString("hh:mm tt")</div>
                            </td>
                            <td>
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2">@log.Action</span>
                            </td>
                            <td class="text-dark">@log.Details</td>
                            <td class="pe-4 text-muted">@log.PerformedBy</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
