@model SchoolApp.Models.TransactionModel
@{
    ViewData["Title"] = "Add Transaction";
}

<h2 class="mb-4">➕ Add Transaction</h2>
<div class="card shadow-sm border-0" style="max-width:500px">
    <div class="card-body p-4">
        <form asp-action="Create" asp-route-role="@ViewBag.Role" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-semibold"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Amount" class="form-label fw-semibold"></label>
                <div class="input-group">
                    <span class="input-group-text">₱</span>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                </div>
                <span asp-validation-for="Amount" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Category" class="form-label fw-semibold"></label>
                <select asp-for="Category" class="form-select">
                    <option value="General">General</option>
                    <option value="Payment">Payment</option>
                    <option value="Refund">Refund</option>
                    <option value="Order">Order</option>
                </select>
            </div>
            <button type="submit" class="btn btn-success">Save Transaction</button>
            <a asp-action="Index" asp-route-role="@ViewBag.Role" class="btn btn-secondary ms-2">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}