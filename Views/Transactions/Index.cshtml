@model List<SchoolApp.Models.TransactionModel>
@{
    ViewData["Title"] = "Transactions";
    ViewData["Subtitle"] = "Manage and track all school-related financial records.";
    var role = ViewBag.Role as string;
    var isAdmin = role == "admin";
}



<div class="filter-section mb-4 shadow-sm">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
        <div>
            <h6 class="fw-bold mb-0 text-dark">Filter Transactions</h6>
            <small class="text-muted">Showing @Model.Count record(s) on this page</small>
        </div>
        @if (isAdmin)
        {
            <button type="button" class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#createTransactionModal">
                <i class="bi bi-plus-lg me-2"></i>New Transaction
            </button>
        }
    </div>

    <form method="get" class="row g-2 align-items-end">
        <div class="col-sm-12 col-md-4">
            <label class="form-label small fw-bold text-uppercase text-muted">Search Description</label>
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" name="search" class="form-control border-start-0" placeholder="e.g. Tuition fee..." value="@ViewBag.Search" />
            </div>
        </div>

        <div class="col-sm-12 col-md-3">
            <label class="form-label small fw-bold text-uppercase text-muted">Category</label>
            <select name="category" class="form-select">
                <option value="" selected="@(string.IsNullOrEmpty((string?)ViewBag.Category) ? "selected" : null)">All Categories</option>
                <option value="General" selected="@((string?)ViewBag.Category == "General" ? "selected" : null)">General</option>
                <option value="Payment" selected="@((string?)ViewBag.Category == "Payment" ? "selected" : null)">Payment</option>
                <option value="Refund" selected="@((string?)ViewBag.Category == "Refund" ? "selected" : null)">Refund</option>
                <option value="Order" selected="@((string?)ViewBag.Category == "Order" ? "selected" : null)">Order</option>
            </select>
        </div>

        <div class="col-sm-12 col-md-2">
            <label class="form-label small fw-bold text-uppercase text-muted">Date From</label>
            <input type="date" name="dateFrom" class="form-control px-2" value="@ViewBag.DateFrom" />
        </div>

        <div class="col-sm-12 col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-outline-primary flex-grow-1">
                <i class="bi bi-funnel me-1"></i> Apply
            </button>
            <a href="@Url.Action("Index", "Transactions")" class="btn btn-light border flex-grow-1">
                <i class="bi bi-x-circle me-1"></i> Clear
            </a>
        </div>
    </form>
</div>

<div class="card border-0 shadow-sm table-card">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-muted border-bottom-0">ID</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted border-bottom-0">Date</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted border-bottom-0">Description</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted border-bottom-0">Category</th>
                    <th class="py-3 text-end pe-4 text-uppercase small fw-bold text-muted border-bottom-0">Amount</th>
                    @if (isAdmin)
                    {
                        <th class="py-3 pe-4 text-end text-uppercase small fw-bold text-muted border-bottom-0">Actions</th>
                    }
                </tr>
            </thead>
            <tbody class="border-top-0">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="@(isAdmin ? 6 : 5)" class="text-center py-5">
                            <i class="bi bi-inbox text-light display-1 d-block mb-3"></i>
                            <span class="text-muted fw-medium">No records matching your criteria.</span>
                        </td>
                    </tr>
                }
                @foreach (var t in Model)
                {
                    // Clean Bootstrap utility classes for badges
                    string badgeClasses = t.Category switch
                    {
                                "Payment" => "bg-success bg-opacity-10 text-success border border-success border-opacity-25",
                                "Refund" => "bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25",
                                "Order" => "bg-info bg-opacity-10 text-info border border-info border-opacity-25",
                        _ => "bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25"
                    };

                    <tr>
                        <td class="ps-4 text-muted small">@t.TransactionId</td>
                        <td>
                            <div class="fw-medium text-dark">@t.Date.ToString("MMM dd")</div>
                            <div class="small text-muted">@t.Date.Year</div>
                        </td>
                        <td>
                            <span class="fw-semibold text-dark">@t.Description</span>
                        </td>
                        <td>
                            <span class="badge @badgeClasses rounded-pill px-3 py-2 fw-medium">@t.Category</span>
                        </td>
                        <td class="text-end pe-4">
                            <span class="fw-bold @(t.Category == "Refund" ? "text-danger" : "text-success")">
                                @(t.Category == "Refund" ? "-" : "+")₱@t.Amount.ToString("N2")
                            </span>
                        </td>
                        @if (isAdmin)
                        {
                            <td class="text-end pe-4">
                                <button type="button" class="btn btn-sm btn-light border text-danger" title="Delete"
                                        data-bs-toggle="modal" data-bs-target="#deleteTransactionModal"
                                        data-transaction-id="@t.TransactionId" 
                                        data-transaction-desc="@t.Description"
                                        data-transaction-amount="@t.Amount"
                                        data-transaction-category="@t.Category">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        }
                    </tr>
                }
            </tbody>
            @if (Model.Any())
            {
                <tfoot class="bg-light border-top-0">
                    <tr>
                        <td colspan="@(isAdmin ? 5 : 4)" class="text-end py-3 text-muted fw-bold text-uppercase small">Total Summary:</td>
                        <td class="text-end pe-4 py-3 fs-5 mb-0 fw-bold text-primary">₱@Model.Sum(t => t.Amount).ToString("N2")</td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</div>

@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

@if (totalPages > 1)
{
    <nav class="mt-4 mb-4" aria-label="Transactions pagination">
        <ul class="pagination modern-pagination justify-content-center mb-0">
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, category = ViewBag.Category, dateFrom = ViewBag.DateFrom, page = currentPage - 1 })" aria-label="Previous">
                    <i class="bi bi-chevron-left fs-6"></i>
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, category = ViewBag.Category, dateFrom = ViewBag.DateFrom, page = i })">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, category = ViewBag.Category, dateFrom = ViewBag.DateFrom, page = currentPage + 1 })" aria-label="Next">
                    <i class="bi bi-chevron-right fs-6"></i>
                </a>
            </li>
        </ul>
    </nav>
}

@if (isAdmin)
{
    <div class="modal fade" id="createTransactionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white border-bottom-0 pb-3">
                    <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2"></i>Record Transaction</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="Create" method="post">
                    <div class="modal-body p-4">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label text-muted small fw-bold text-uppercase">Description</label>
                                <textarea name="Description" class="form-control bg-light border-0" rows="2" placeholder="e.g., Monthly Tuition..." required></textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-bold text-uppercase">Category</label>
                                <select name="Category" class="form-select bg-light border-0" required>
                                    <option value="General">General</option>
                                    <option value="Payment">Payment</option>
                                    <option value="Refund">Refund</option>
                                    <option value="Order">Order</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label text-muted small fw-bold text-uppercase">Amount</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-0 text-muted">₱</span>
                                    <input name="Amount" type="number" step="0.01" min="0.01" class="form-control bg-light border-0" required />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-top-0 p-4 pt-0">
                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                        <button class="btn btn-primary px-4 shadow-sm" type="submit">Save Record</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="deleteTransactionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Deletion</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-4 text-center">
                    <div class="mb-3">
                        <i class="bi bi-trash3 text-danger" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="fw-bold mb-2">Are you sure?</h5>
                    <p class="text-muted mb-3">You are about to permanently delete this transaction:</p>
                    <div class="bg-light p-3 rounded mb-2 text-start">
                        <small class="text-muted d-block mb-1"><strong>Description:</strong></small>
                        <div class="text-dark fw-semibold mb-2" id="deleteTransactionDesc"></div>
                        
                        <small class="text-muted d-block mb-1"><strong>Category:</strong></small>
                        <div class="text-dark fw-semibold mb-2" id="deleteTransactionCategory"></div>
                        
                        <small class="text-muted d-block mb-1"><strong>Amount:</strong></small>
                        <div class="text-danger fw-bold" id="deleteTransactionAmount"></div>
                    </div>
                    <p class="text-muted mb-0 small"><strong>This action cannot be undone.</strong></p>
                </div>
                <div class="modal-footer border-top-0 p-4 pt-0 justify-content-center">
                    <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Cancel</button>
                    <form asp-action="Delete" method="post" id="deleteTransactionForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" id="deleteTransactionId" />
                        <button class="btn btn-danger px-4 shadow-sm" type="submit">Delete Permanently</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Delete Transaction Modal - Populate with transaction data
        const deleteTransactionModal = document.getElementById('deleteTransactionModal');
        if (deleteTransactionModal) {
            deleteTransactionModal.addEventListener('show.bs.modal', function (event) {
                const button = event.relatedTarget;
                const transactionId = button.getAttribute('data-transaction-id');
                const transactionDesc = button.getAttribute('data-transaction-desc');
                const transactionAmount = button.getAttribute('data-transaction-amount');
                const transactionCategory = button.getAttribute('data-transaction-category');

                document.getElementById('deleteTransactionId').value = transactionId;
                document.getElementById('deleteTransactionDesc').textContent = transactionDesc;
                document.getElementById('deleteTransactionAmount').textContent = '₱' + parseFloat(transactionAmount).toFixed(2);
                document.getElementById('deleteTransactionCategory').textContent = transactionCategory;
            });
        }
    </script>
}