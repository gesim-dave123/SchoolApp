@model List<SchoolApp.Models.TransactionModel>
@{
    ViewData["Title"] = "Transactions"; var role = ViewBag.Role as string; var isAdmin = role == "admin";
}

<h2 class="mb-3">💳 Transactions</h2>

<form method="get" class="row g-2 mb-3">
    <input type="hidden" name="role" value="@role" />
    <div class="col-auto">
        <input type="text" name="search" class="form-control" placeholder="Search description..." value="@ViewBag.Search" />
    </div>
    <div class="col-auto">
        <select name="category" class="form-select">
            <option value="">All Categories</option>
            <option value="General">General</option>
            <option value="Payment">Payment</option>
            <option value="Refund">Refund</option>
            <option value="Order">Order</option>
        </select>
    </div>
    <div class="col-auto">
        <input type="date" name="dateFrom" class="form-control" title="Filter from date" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">🔍 Filter</button>
    </div>
    @if (isAdmin)
    {
        <div class="col-auto ms-auto">
            <a asp-action="Create" asp-route-role="@role" class="btn btn-success">+ Add Transaction</a>
        </div>
    }
</form>

<div class="card shadow-sm border-0">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr><th>ID</th><th>Date</th><th>Description</th><th>Category</th><th>Amount</th></tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No transactions found.</td></tr>
                }
                @foreach (var t in Model)
                {
                    <tr>
                        <td>#@t.TransactionId</td>
                        <td>@t.Date.ToString("MMM dd, yyyy")</td>
                        <td>@t.Description</td>
                        <td><span class="badge bg-secondary">@t.Category</span></td>
                        <td class="fw-semibold text-success">₱@t.Amount.ToString("N2")</td>
                    </tr>
                }
            </tbody>
            @if (Model.Any())
            {
                <tfoot class="table-light">
                    <tr>
                        <td colspan="4" class="text-end fw-bold">Total:</td>
                        <td class="fw-bold text-success">₱@Model.Sum(t => t.Amount).ToString("N2")</td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</div>