@model List<SchoolApp.Models.TransactionModel>
@{
    ViewData["Title"] = "Transactions";
    var role = ViewBag.Role as string;
    var isAdmin = role == "admin";
}

<style>
    .table-card {
        border-radius: 16px;
        overflow: hidden;
    }

    .filter-section {
        background: #fff;
        padding: 15px;
        border-radius: 12px;
        border: 1px solid #eef2f7;
    }

    .badge-payment {
        background-color: #dcfce7;
        color: #166534;
    }

    .badge-refund {
        background-color: #fee2e2;
        color: #991b1b;
    }

    .badge-order {
        background-color: #e0f2fe;
        color: #075985;
    }

    .badge-general {
        background-color: #f1f5f9;
        color: #475569;
    }
</style>

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="h3 mb-1 fw-bold text-dark">Transaction History</h2>
        <p class="text-muted small mb-0">Manage and track all school-related financial records.</p>
    </div>
    @if (isAdmin)
    {
        <div class="col-auto">
            <button type="button" class="btn btn-primary shadow-sm px-4" data-bs-toggle="modal" data-bs-target="#createTransactionModal">
                <i class="bi bi-plus-lg me-2"></i>New Transaction
            </button>
        </div>
    }
</div>

<div class="filter-section mb-4 shadow-sm">
    <form method="get" class="row g-3 align-items-end">
        <input type="hidden" name="role" value="@role" />
        <div class="col-md-4">
            <label class="form-label small fw-bold text-uppercase text-muted">Search Description</label>
            <div class="input-group">
                <span class="input-group-text bg-transparent border-end-0"><i class="bi bi-search"></i></span>
                <input type="text" name="search" class="form-control border-start-0" placeholder="e.g. Tuition fee..." value="@ViewBag.Search" />
            </div>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold text-uppercase text-muted">Category</label>
            <select name="category" class="form-select">
                <option value="">All Categories</option>
                <option value="General">General</option>
                <option value="Payment">Payment</option>
                <option value="Refund">Refund</option>
                <option value="Order">Order</option>
            </select>
        </div>
        <div class="col-md-3">
            <label class="form-label small fw-bold text-uppercase text-muted">Date From</label>
            <input type="date" name="dateFrom" class="form-control" />
        </div>
        <div class="col-md-2">
            <button type="submit" class="btn btn-outline-primary w-100">
                <i class="bi bi-funnel me-1"></i> Apply
            </button>
        </div>
    </form>
</div>

<div class="card border-0 shadow-sm table-card">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 py-3 text-uppercase small fw-bold text-muted">ID</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Date</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Description</th>
                    <th class="py-3 text-uppercase small fw-bold text-muted">Category</th>
                    <th class="py-3 text-end pe-4 text-uppercase small fw-bold text-muted">Amount</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="bi bi-inbox text-light display-1 d-block mb-3"></i>
                            <span class="text-muted fw-medium">No records matching your criteria.</span>
                        </td>
                    </tr>
                }
                @foreach (var t in Model)
                {
                    // Helper logic for badges
                    string badgeClass = t.Category switch
                    {
                                "Payment" => "badge-payment",
                                "Refund" => "badge-refund",
                                "Order" => "badge-order",
                        _ => "badge-general"
                    };

                    <tr>
                        <td class="ps-4 text-muted">#@t.TransactionId</td>
                        <td>
                            <div class="fw-medium">@t.Date.ToString("MMM dd")</div>
                            <div class="small text-muted">@t.Date.Year</div>
                        </td>
                        <td>
                            <div class="fw-semibold text-dark">@t.Description</div>
                        </td>
                        <td>
                            <span class="badge @badgeClass rounded-pill px-3">@t.Category</span>
                        </td>
                        <td class="text-end pe-4">
                            <span class="fw-bold @(t.Category == "Refund" ? "text-danger" : "text-success")">
                                @(t.Category == "Refund" ? "-" : "+")₱@t.Amount.ToString("N2")
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
            @if (Model.Any())
            {
                <tfoot class="bg-light border-top-0">
                    <tr>
                        <td colspan="4" class="text-end py-3 text-muted fw-bold text-uppercase small">Total Summary:</td>
                        <td class="text-end pe-4 py-3 h5 mb-0 fw-bold text-primary">₱@Model.Sum(t => t.Amount).ToString("N2")</td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</div>

@if (isAdmin)
{
    <div class="modal fade" id="createTransactionModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title fw-bold"><i class="bi bi-plus-circle me-2"></i>Record Transaction</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="Create" method="post">
                    <div class="modal-body p-4">
                        @Html.AntiForgeryToken()
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-bold small">Transaction Description</label>
                                <textarea name="Description" class="form-control bg-light" rows="2" placeholder="What is this payment for?" required></textarea>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Category</label>
                                <select name="Category" class="form-select bg-light" required>
                                    <option value="General">General</option>
                                    <option value="Payment">Payment</option>
                                    <option value="Refund">Refund</option>
                                    <option value="Order">Order</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small">Amount</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-white border-end-0">₱</span>
                                    <input name="Amount" type="number" step="0.01" min="0.01" class="form-control border-start-0 bg-white" required />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-top-0 p-4 pt-0">
                        <button type="button" class="btn btn-light px-4" data-bs-dismiss="modal">Discard</button>
                        <button class="btn btn-primary px-4 shadow-sm" type="submit">Create Record</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}